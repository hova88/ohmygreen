# web
OHMYGREEN_ENV=development
OHMYGREEN_SESSION_SECRET=dev-secret-change-in-production
DATABASE_URL=sqlite:///./ohmygreen.db

# api
# API uses the same DB/session settings as web.

# cli
OHMYGREEN_BASE_URL=http://127.0.0.1:8000
OHMYGREEN_AI_PROVIDER=openai

# ai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
